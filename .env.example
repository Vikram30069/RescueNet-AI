# ==============================
# RescueNet AI — Environment Variables Template
# Copy this file to .env and fill in your values
# ==============================

# ---- App ----
APP_ENV=development
APP_PORT=8000
SECRET_KEY=your-secret-key-here

# ---- Database (Supabase / PostgreSQL) ----
DATABASE_URL=postgresql://user:password@localhost:5432/rescuenet
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- LLM Provider (choose ONE or set PROVIDER=mock for local dry-run) ----
# Options: openai | gemini | ollama | litellm | mock
LLM_PROVIDER=mock

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Google Gemini (used when LLM_PROVIDER=gemini)
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-pro

# Ollama — local fallback (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# LiteLLM proxy (used when LLM_PROVIDER=litellm)
LITELLM_BASE_URL=http://localhost:4000
LITELLM_MODEL=openai/gpt-4o

# ---- Maps ----
GOOGLE_MAPS_API_KEY=your-google-maps-key

# ---- AWS ----
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=rescuenet-ai-storage
AWS_BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# ---- Alerts ----
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_FROM=+1...

SNS_ALERT_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:RescueAlerts

# ---- CORS ----
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
